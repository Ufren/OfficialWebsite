---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero';
import { Features } from '../components/Features';
import { DeepDive } from '../components/DeepDive';
import { Testimonials } from '../components/Testimonials';
import { Navbar } from '../components/Navbar';
import { AppConfig } from '../config';
---

<Layout title="Ufren AI Desktop - The Ultimate AI Workspace">
	<main>
		<Navbar client:load />
		<Hero client:load />
		<Features client:visible />
		<DeepDive client:visible />
		<Testimonials client:visible />
	</main>
	
	<footer className="py-8 text-center text-slate-500 text-sm border-t border-slate-900 bg-slate-950">
		<div className="container mx-auto px-4 flex flex-col gap-2">
			<p>&copy; {new Date().getFullYear()} Ufren AI Desktop. All rights reserved.</p>
			<p className="flex items-center justify-center gap-2">
				<img src="/beian.png" alt="" className="w-4 h-4 opacity-50 hidden" onError={(e) => e.currentTarget.style.display = 'none'} />
				<a href={AppConfig.beian.link} target="_blank" rel="noopener noreferrer" className="hover:text-slate-400 transition-colors">
					{AppConfig.beian.number}
				</a>
			</p>
		</div>
	</footer>
</Layout>
