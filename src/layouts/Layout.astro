---
import { GradientBackground } from '../components/GradientBackground';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="UfrenClaw - Modern Desktop AI Assistant built with Electron, React, and OpenClaw" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
  </head>
  <body class="bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] antialiased">
    <GradientBackground client:load />
    <svg class="noise-overlay" width="100%" height="100%">
      <filter id="noise">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noise)" />
    </svg>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
